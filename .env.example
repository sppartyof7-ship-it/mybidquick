# ============================================================================
# MyBidQuick Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# VITE_ prefixed vars are exposed to the frontend browser bundle.
# Non-VITE_ vars are server-side only (Vercel serverless functions).
# ============================================================================

# --- Supabase (public — safe for frontend) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# --- Supabase (server-side only — NEVER prefix with VITE_) ---
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Stripe (public — safe for frontend) ---
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# --- Stripe (server-side only — NEVER prefix with VITE_) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Admin Dashboard ---
# WARNING: This is exposed in the frontend bundle via VITE_ prefix.
# Anyone who decompiles the JS can see it. Use a strong password.
# TODO: Move to server-side auth in Phase 4.
VITE_ADMIN_PASSWORD=your-strong-password-here

# --- Email (server-side only) ---
RESEND_API_KEY=re_...

# --- Web3Forms (notification on new signups) ---
VITE_WEB3FORMS_KEY=your-web3forms-access-key
